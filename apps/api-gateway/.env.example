# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# Auth
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
API_KEY_HEADER=x-api-key

# Services (downstream)
PREFERENCE_SERVICE_URL=http://localhost:3001
SCHEDULE_SERVICE_URL=http://localhost:3002
CONTEXT_SERVICE_URL=http://localhost:3003
AUTH_SERVICE_URL=http://localhost:3004

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info